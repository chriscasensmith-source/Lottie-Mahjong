# Copy this file to .env.local and fill in your Supabase project values.
# Find these in Supabase: Project Settings -> API.
#
# NOTE: These are the *publishable* (anon) values and are safe to ship in a
# client-side app. Row Level Security on the database controls real access.
#
# If these are left blank, the app falls back to storing wins in the
# browser's localStorage so you can still try it out offline.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
